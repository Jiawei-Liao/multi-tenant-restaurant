SPRING_DATASOURCE_URL=jdbc:postgresql://<host>/<database>?sslmode=require&channelBinding=require
SPRING_DATASOURCE_USERNAME=<username>
SPRING_DATASOURCE_PASSWORD=<password>

STORAGE_S3_ENDPOINT=<endpoint-url>
STORAGE_S3_BUCKET=<bucket-name>
STORAGE_S3_REGION=<region>
STORAGE_S3_ACCESS_KEY=<access-key>
STORAGE_S3_SECRET_KEY=<secret-key>
STORAGE_S3_PUBLIC_URL=<public-base-url>

JWT_SECRET=<jwt-secret>

# Use false only for local HTTP development. Production must use true.
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=Lax
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173,http://127.0.0.1:5173
